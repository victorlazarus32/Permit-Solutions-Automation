# Copy this file to .env and fill in values.
# Never commit .env to source control.

# === Lob credentials ===
# Get from https://dashboard.lob.com/settings/api-keys
# Use the test_* key while developing; switch to live_* when ready to mail real letters.
LOB_API_KEY=test_PLACEHOLDER_REPLACE_ME

# === Your return address ===
# One-time setup: create your Permit Solutions Services return address in the
# Lob dashboard (or use scripts/upload_template.py --create-from-address) and
# paste the resulting adr_xxx ID here.
LOB_FROM_ADDRESS_ID=adr_PLACEHOLDER

# === Letter template ===
# After running:  python -m scripts.upload_template
# paste the returned tmpl_xxx ID here. If left blank, the system falls back to
# sending the inline HTML on every request (works fine, just slower per call).
LOB_TEMPLATE_ID=

# === Print options ===
LOB_COLOR=true
# Our letter template has an English front and a Spanish back. Keep this true
# so Lob prints both sides on one sheet (saves paper + postage).
LOB_DOUBLE_SIDED=true
LOB_MAIL_TYPE=usps_first_class

# === Webhook receiver ===
# After you configure a webhook in the Lob dashboard
# (https://dashboard.lob.com/#/settings/webhooks), Lob shows you a signing
# secret beginning with `whsec_`. Paste it here so the receiver can verify
# incoming events. Without this, all incoming webhooks are rejected.
LOB_WEBHOOK_SECRET=whsec_PLACEHOLDER

# DEV ONLY: set to 1 to skip signature verification (e.g. when testing locally
# without a real Lob webhook configured). Never enable in production.
# LOB_WEBHOOK_SKIP_VERIFICATION=1

# === Test recipient (for scripts/send_test_to_self.py) ===
# When you run "python -m scripts.send_test_to_self --limit 5", every letter
# is rerouted to this address (no matter who the real property owner is).
# Use this for visual QA before mass-mailing real recipients. The DB is NOT
# touched, so the same cases will still go out to the real owners on the
# next production run.
TEST_RECIPIENT_NAME=Victor L. Moreno
TEST_RECIPIENT_LINE1=
TEST_RECIPIENT_LINE2=
TEST_RECIPIENT_CITY=
TEST_RECIPIENT_STATE=FL
TEST_RECIPIENT_ZIP=

