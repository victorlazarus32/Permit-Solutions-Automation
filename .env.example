# Copy this file to .env and fill in values.
# Never commit .env to source control.

# === Lob credentials — LIVE ===
# Get from https://dashboard.lob.com/settings/api-keys (live key starts live_*).
# All production sends (morning_run, dashboard "Mail Today's Letters") use this.
LOB_API_KEY=live_PLACEHOLDER_REPLACE_ME

# === Your return address (LIVE) ===
# One-time setup: create your Permit Solutions Services return address in the
# Lob dashboard and paste the resulting adr_xxx ID here.
LOB_FROM_ADDRESS_ID=adr_PLACEHOLDER

# === Letter template (LIVE) ===
# After running:  python -m scripts.upload_template
# paste the returned tmpl_xxx ID here. If left blank, the system falls back to
# sending the inline HTML on every request (works fine, just slower per call).
LOB_TEMPLATE_ID=

# === Lob credentials — TEST (review-only, no real mail) ===
# Test keys start with test_*. Letters sent with the test key are rendered
# by Lob into a PDF you can view in the dashboard, but NOTHING physically
# prints or mails. Postage is free. Use scripts/send_test_to_self.py
# --test-api to send through this key for visual review.
LOB_TEST_API_KEY=test_PLACEHOLDER_REPLACE_ME

# Lob keeps test-mode resources separate from live. On the first --test-api
# send, the script auto-creates a test from-address + uploads the template
# under test mode and writes the resulting IDs back here. Leave blank to
# trigger bootstrap.
LOB_TEST_FROM_ADDRESS_ID=
LOB_TEST_TEMPLATE_ID=

# === Print options ===
LOB_COLOR=true
# Our letter template has an English front and a Spanish back. Keep this true
# so Lob prints both sides on one sheet (saves paper + postage).
LOB_DOUBLE_SIDED=true
LOB_MAIL_TYPE=usps_first_class

# Where Lob places the return + recipient address blocks on the printed letter.
#   insert_blank_page  -- (default) addresses on their own first page, letter
#                          content untouched. Adds one sheet of paper per
#                          mailpiece but keeps the letterhead clean.
#   top_first_page     -- Lob overlays the address blocks on top of your
#                          letter's page 1. Lower paper cost but collides with
#                          any letterhead/logo at the top of the page.
LOB_ADDRESS_PLACEMENT=insert_blank_page

# === Webhook receiver ===
# After you configure a webhook in the Lob dashboard
# (https://dashboard.lob.com/#/settings/webhooks), Lob shows you a signing
# secret beginning with `whsec_`. Paste it here so the receiver can verify
# incoming events. Without this, all incoming webhooks are rejected.
LOB_WEBHOOK_SECRET=whsec_PLACEHOLDER

# DEV ONLY: set to 1 to skip signature verification (e.g. when testing locally
# without a real Lob webhook configured). Never enable in production.
# LOB_WEBHOOK_SKIP_VERIFICATION=1

# === Test recipient (for scripts/send_test_to_self.py) ===
# When you run "python -m scripts.send_test_to_self --limit 5", every letter
# is rerouted to this address (no matter who the real property owner is).
# Use this for visual QA before mass-mailing real recipients. The DB is NOT
# touched, so the same cases will still go out to the real owners on the
# next production run.
TEST_RECIPIENT_NAME=Victor L. Moreno
TEST_RECIPIENT_LINE1=
TEST_RECIPIENT_LINE2=
TEST_RECIPIENT_CITY=
TEST_RECIPIENT_STATE=FL
TEST_RECIPIENT_ZIP=

